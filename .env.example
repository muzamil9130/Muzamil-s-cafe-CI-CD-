# ─── App secrets (required) ──────────────────────────────────
GEMINI_API_KEY="your-gemini-api-key"
APP_URL="http://localhost:5000"

# ─── MongoDB ─────────────────────────────────────────────────
MONGODB_URI="mongodb://localhost:27017/cafe-muzamil"

# ─── Docker Compose local overrides (optional) ───────────────
MONGO_ROOT_USER="admin"
MONGO_ROOT_PASS="secret"

# ─── App ─────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development
